# Notion API設定
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Yahoo Shopping API設定
YAHOO_API_KEY=your_yahoo_api_key
YAHOO_API_SECRET=your_yahoo_api_secret
YAHOO_STORE_ACCOUNT=your_store_account

# 楽天 RMS API設定
RAKUTEN_SERVICE_SECRET=your_service_secret
RAKUTEN_LICENSE_KEY=your_license_key
RAKUTEN_SHOP_URL=https://www.rakuten.co.jp/yourshop/

# 実行設定
DRY_RUN=false  # true にすると実際の更新は行わず、ログのみ出力
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
